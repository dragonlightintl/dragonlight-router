# .env.example — copy to .env and fill in your keys

# Provider API keys — set only the providers you use
NVIDIA_NIM_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
CEREBRAS_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
COHERE_API_KEY=
TOGETHER_API_KEY=

# Server configuration
DRAGONLIGHT_ROUTER_CONFIG=./config/router.yaml
DRAGONLIGHT_HOST=127.0.0.1
DRAGONLIGHT_PORT=8100
DRAGONLIGHT_GRACEFUL_SHUTDOWN_TIMEOUT=10

# Admin API key for protected endpoints (retire, reinstate, catalog/refresh)
# DRAGONLIGHT_ADMIN_API_KEY=
